# Supabase — create project at supabase.com, copy from Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Anthropic — Claude powers the onboarding AI + admin chat
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — DALL-E 3 powers logo + food photo generation. If unset, logos
# fall back to a Claude-generated SVG (lower quality) and food photo
# generation returns 503.
OPENAI_API_KEY=sk-...

# Xendit — online payments (QRIS, DANA, OVO, ShopeePay). Leave blank until
# you turn on digital payments; the code rejects attempts with a clear error.
XENDIT_SECRET_KEY=
# The callback token Xendit signs webhooks with. Must match what you set
# in the Xendit dashboard → Settings → Callbacks.
XENDIT_CALLBACK_TOKEN=

# Fonnte WhatsApp — transactional order receipts. Notifications are stubbed
# with console.log when unset.
FONNTE_TOKEN=

# Platform root domain — used for subdomain parsing + marketing links
PLATFORM_DOMAIN=sajian.app

# Cookie domain for the Supabase auth session. Must start with a dot so
# the cookie is valid on apex AND subdomains (sajian.app, mindiology.sajian.app).
# Leave BLANK on localhost — browsers reject a Domain attribute without a dot.
NEXT_PUBLIC_COOKIE_DOMAIN=

# Origin the /setup iframe loads for live preview. Set to a dedicated
# origin (e.g. https://preview.sajian.app) in production so the preview
# sandbox runs in an opaque-origin context with no access to the parent's
# auth cookies. Leave BLANK on localhost — code falls back to same-origin
# for dev.
NEXT_PUBLIC_PREVIEW_ORIGIN=

# Flip to "1" to enforce Content-Security-Policy. When unset we ship
# Content-Security-Policy-Report-Only so violations are logged without
# breaking anything. Start in report mode, watch /api/csp-report logs,
# fix real violations, then flip this to "1".
CSP_ENFORCE=

# Local dev — base URL used by server code that needs an absolute URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000
