# Supabase — create project at supabase.com, copy from Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Xendit — Phase 2 (online payments). Leave blank until needed.
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# Fonnte WhatsApp — Phase 2. Notifications are stubbed with console.log for now.
FONNTE_TOKEN=

# Platform root domain — used for subdomain parsing + marketing links
PLATFORM_DOMAIN=sajian.app

# Local dev — base URL used by server code that needs an absolute URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000
